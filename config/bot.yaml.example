# bot.yaml — Bot 配置
# 复制此文件为 bot.yaml 并填入实际的 accessToken
# enabled: false 表示禁用此 Bot，配置完成后将其改为 true

bot:
  botId: my-bot
  enabled: false
  mode: hybrid
  ws:
    url: ws://127.0.0.1:6700/
    accessToken: ""  # 填入你的 WS accessToken
    heartbeatIntervalMs: 30000
    reconnectIntervalMs: 5000
  http:
    baseUrl: http://127.0.0.1:5700/
    accessToken: ""  # 填入你的 HTTP accessToken
    timeoutMs: 5000
