{
  "name": "dian",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "plugin-template"
  ],
  "scripts": {
    "build": "npm run build -w packages && npm run build -w apps/server",
    "start": "npm run start -w apps/server",
    "dev": "npm run dev -w packages & npm run dev -w apps/server",
    "dev:web": "npm run dev -w apps/web",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitepress": "^1.6.4"
  }
}