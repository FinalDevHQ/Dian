{
  "name": "dian",
  "version": "0.1.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w packages && npm run build -w apps/server",
    "start": "npm run start -w apps/server",
    "dev": "npm run dev -w packages & npm run dev -w apps/server",
    "dev:web": "npm run dev -w apps/web",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@nolebase/vitepress-plugin-enhanced-readabilities": "^2.18.2",
    "typescript": "^5.6.3",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "undici": "^7.26.0"
  }
}
